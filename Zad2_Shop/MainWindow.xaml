<Window x:Class="Zad2_Shop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин" Height="550" Width="750">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Grid.Row="0" Text="ПРОДУКТОВЫЙ МАГАЗИН" 
                   FontSize="22" FontWeight="Bold" TextAlignment="Center" 
                   Background="LightGray" Padding="10" Margin="0,0,0,10"/>

        <!-- Создание товара -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" 
                Padding="10" Margin="0,5" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Добавление товара" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtName" Width="150" Margin="0,0,5,0" ToolTip="Наименование"/>
                    <TextBox x:Name="txtPrice" Width="80" Margin="0,0,5,0" ToolTip="Цена"/>
                    <TextBox x:Name="txtCount" Width="80" Margin="0,0,5,0" ToolTip="Количество"/>
                    <Button x:Name="btnCreate" Content="Создать" Width="80" 
                            Click="BtnCreate_Click" Background="LightGreen"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Продажа товара -->
        <Border Grid.Row="2" BorderBrush="Gray" BorderThickness="1" 
                Padding="10" Margin="0,5" CornerRadius="5">
            <StackPanel>
                <TextBlock Text="Продажа товара" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="txtSellName" Width="150" Margin="0,0,5,0" ToolTip="Наименование"/>
                    <TextBox x:Name="txtSellCount" Width="80" Margin="0,0,5,0" Text="1" ToolTip="Количество"/>
                    <Button x:Name="btnSell" Content="Продать" Width="80" 
                            Click="BtnSell_Click" Background="LightCoral"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Кнопки управления -->
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="1" 
                Padding="10" Margin="0,5" CornerRadius="5">
            <WrapPanel HorizontalAlignment="Center">
                <Button x:Name="btnShowProfit" Content= "Показать прибыль" Width="700" 
                        Click="BtnShowProfit_Click" Margin="0,0,0,5"/>
                <Button x:Name="btnShowStats" Content="Статистика" Width="700" 
                        Click="BtnShowStats_Click" Margin="0,0,0,5"/>
            </WrapPanel>
        </Border>

        <!-- Список товаров -->
        <Border Grid.Row="5" BorderBrush="Gray" BorderThickness="1" 
                Padding="10" Margin="0,5" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Текущий список товаров" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>

                <ListBox x:Name="lstProducts" Grid.Row="1" Margin="0,5" MinHeight="200"/>
            </Grid>
        </Border>
    </Grid>
</Window>