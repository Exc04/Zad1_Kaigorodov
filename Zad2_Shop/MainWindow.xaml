<Window x:Class="Zad2_Shop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Магазин" Height="550" Width="750">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Меню на всю ширину -->
        <Menu Grid.Row="0" Grid.ColumnSpan="2" Margin="0,0,0,10">
            <MenuItem Header="Действия">
                <MenuItem Header="Добавить товар" Click="MenuAdd_Click"/>
                <MenuItem Header="Продать товар" Click="MenuSell_Click"/>
                <Separator/>
                <MenuItem Header="Выход" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="Статистика" Click="MenuItem_Click">
                <MenuItem Header="Показать все товары" Click="MenuShowAll_Click"/>
                <MenuItem Header="Статистика магазина" Click="MenuReport_Click"/>
            </MenuItem>
        </Menu>

        <!-- Левая панель: Добавление товара -->
        <GroupBox Header=" Добавить товар" Grid.Row="1" Grid.Column="0" Margin="0,0,10,10">
            <StackPanel Margin="10">
                <TextBlock Text="Название товара" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtName" Margin="0,0,0,10" Padding="5" Tag="Название"/>

                <TextBlock Text="Цена (₽)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtPrice" Margin="0,0,0,10" Padding="5" Tag="Цена"/>

                <TextBlock Text="Количество (шт.)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCount" Margin="0,0,0,15" Padding="5" Tag="Количество"/>

                <Button x:Name="btnAdd" Content="Добавить в ассортимент" Click="BtnAdd_Click" 
                        Background="#4CAF50" Foreground="White" FontWeight="Bold" 
                        Padding="10" Cursor="Hand"/>
            </StackPanel>
        </GroupBox>

        <!-- Правая панель: Продажа товара -->
        <GroupBox Header=" Продать товар" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
            <StackPanel Margin="10">
                <TextBlock Text="Название товара" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSellName" Margin="0,0,0,10" Padding="5" Tag="Название"/>

                <TextBlock Text="Количество для продажи (шт.)" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtSellCount" Margin="0,0,0,15" Padding="5" Tag="Кол-во" Text="1"/>

                <Button x:Name="btnSell" Content="Оформить продажу" Click="BtnSell_Click" 
                        Background="#F44336" Foreground="White" FontWeight="Bold" 
                        Padding="10" Cursor="Hand"/>
            </StackPanel>
        </GroupBox>

        <!-- Список товаров внизу -->
        <GroupBox Header=" Товары в наличии" Grid.Row="2" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Панель с информацией -->
                <Border Grid.Row="0" Background="#F5F5F5" Padding="5" Margin="0,0,0,5">
                    <TextBlock Text="Список активных товаров (название — цена — количество)" 
                               FontSize="11" FontStyle="Italic"/>
                </Border>

                <!-- Сам список -->
                <ListBox x:Name="lbProducts" Grid.Row="1" Height="140" 
                         FontFamily="Consolas" FontSize="13"/>
            </Grid>
        </GroupBox>

        <!-- Статусбар -->
        <StatusBar Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10,0,0">
            <StatusBarItem>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Общая прибыль: " FontWeight="Bold"/>
                    <TextBlock x:Name="tbProfit" FontWeight="Bold" Foreground="Green"/>
                    <TextBlock Text=" ₽" FontWeight="Bold" Foreground="Green"/>
                </StackPanel>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>